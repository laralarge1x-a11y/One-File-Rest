{
  "name": "elite-tok-club",
  "version": "1.0.0",
  "type": "module",
  "description": "TikTok Shop violation recovery portal with real-time Discord sync",
  "main": "server/index.ts",
  "scripts": {
    "start": "concurrently \"tsx server/index.ts\" \"tsx bot-bridge/index.ts\"",
    "dev": "concurrently \"tsx watch server/index.ts\" \"cd client && vite\" \"tsx watch bot-bridge/index.ts\"",
    "build": "cd client && vite build",
    "preview": "cd client && vite preview",
    "db:migrate": "tsx server/db/migrate.ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/node": "^10.51.0",
    "@sentry/tracing": "^7.120.4",
    "axios": "^1.6.5",
    "chart.js": "^4.5.1",
    "cloudinary": "^1.41.0",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "express": "^5.0.0",
    "express-rate-limit": "^7.1.0",
    "express-session": "^1.17.3",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^0.5.0",
    "lucide-react": "^1.14.0",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "redis": "^4.6.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^3.4.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^2.0.12",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "postcss": "^8.4.32",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
