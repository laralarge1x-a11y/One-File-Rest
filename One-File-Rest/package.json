{
  "name": "elite-tok-club",
  "version": "1.0.0",
  "type": "module",
  "description": "TikTok Shop violation recovery portal with real-time Discord sync",
  "main": "server/index.ts",
  "scripts": {
    "start": "concurrently \"tsx server/index.ts\" \"tsx bot-bridge/index.ts\"",
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\" \"tsx watch bot-bridge/index.ts\"",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "tsx server/db/migrate.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.0.0",
    "express-session": "^1.17.3",
    "connect-pg-simple": "^9.0.1",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "pg": "^8.11.3",
    "groq-sdk": "^0.4.1",
    "cloudinary": "^1.41.0",
    "discord.js": "^14.14.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.5",
    "recharts": "^2.10.3",
    "tailwindcss": "^3.4.1",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vite": "^5.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/cors": "^2.8.17",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  }
}
